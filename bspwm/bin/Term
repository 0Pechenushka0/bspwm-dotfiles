#!/bin/sh
# =============================================================
# Modified by Maxim: Only Alacritty, no terminal selector
# =============================================================

CFG_TERM="$HOME/.config/bspwm/config/.term"

# Ensure config exists (only for compatibility)
[ -f "$CFG_TERM" ] || echo "alacritty" > "$CFG_TERM"

# Read config (though we only use alacritty)
read -r MY_TERM < "$CFG_TERM" 2>/dev/null || MY_TERM="alacritty"

# Launch Alacritty with appropriate options
case $1 in
    "--terminal")
        alacritty
        ;;
    "--floating")
        alacritty --class FloaTerm,FloaTerm
        ;;
    "--update")
        alacritty --hold --class FloaTerm,FloaTerm -e paru -Syu --nocombinedupgrade
        ;;
    "--checkupdates")
        alacritty --hold --class Updating,Updating -e Updates --print-updates
        ;;
    "--yazi")
        alacritty --class FloaTerm,YaziTerm -e yazi
        ;;
    "--nvim")
        alacritty -e nvim
        ;;
    "--music")
        alacritty --class FloaTerm,MusicTerm -e ncmpcpp
        ;;
    "--fetch")
        alacritty --class FloaTerm,FetchTerm -e ~/.local/bin/sysfetch
        ;;
    *)
        # Default: just open terminal
        alacritty
        ;;
esac
